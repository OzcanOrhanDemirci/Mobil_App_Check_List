{
  "name": "mobil-app-check-list",
  "version": "1.2.0",
  "description": "Mobile app quality checklist PWA (Turkish/English) with 4-axis content resolution",
  "main": "index.html",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "lint": "eslint js/ tests/ sw.js --max-warnings=0",
    "lint:fix": "eslint js/ tests/ sw.js --fix",
    "format": "prettier --write \"**/*.{js,css,html,md,json,yml}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,md,json,yml}\"",
    "test": "node scripts/run-tests.mjs",
    "sw:check": "node scripts/check-sw-cache-version.mjs",
    "sw:sync": "node scripts/check-sw-cache-version.mjs --fix",
    "serve": "python -m http.server 8000",
    "prepare": "node scripts/install-githooks.mjs"
  },
  "keywords": [
    "pwa",
    "mobile",
    "checklist",
    "quality-assurance",
    "vanilla-js",
    "i18n",
    "offline-first"
  ],
  "author": "Özcan Orhan Demirci <ozcanorhandem@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OzcanOrhanDemirci/Mobil_App_Check_List.git"
  },
  "homepage": "https://github.com/OzcanOrhanDemirci/Mobil_App_Check_List#readme",
  "bugs": {
    "url": "https://github.com/OzcanOrhanDemirci/Mobil_App_Check_List/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
